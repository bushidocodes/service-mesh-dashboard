{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",

    // Mirror webpack/Vite/Jest's `resolve.modules: ["src", ...]` so bare imports
    // like `import x from "utils/head"` or `components/Icon` type-resolve. TS 6
    // deprecated `baseUrl`, so use `paths` (resolved relative to this file): the
    // `*` catch-all maps bare specifiers into src/ and falls back to node_modules.
    "paths": {
      // The Vite build aliases `dygraphs` to its ES5 single-file build; mirror
      // that here so TS resolves the same module the bundler/Jest will load.
      "dygraphs": ["./node_modules/dygraphs/src-es5/dygraph.js"],
      "*": ["./src/*", "./*"]
    },

    // Incremental, pragmatic migration: `strict` is being ratcheted on one flag
    // at a time. allowJs lets the remaining .js test files coexist.
    //
    // Phase 0 — the strict sub-flags that the codebase already satisfies are on.
    // The two expensive flags (`noImplicitAny` ~345 errors, `strictNullChecks`
    // ~62) stay off until their dedicated burn-down phases land, after which
    // `strict: true` replaces this block wholesale.
    "allowJs": true,
    "checkJs": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,
    "alwaysStrict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src", "global.d.ts"],
  "exclude": ["node_modules", "build", ".claude"]
}
