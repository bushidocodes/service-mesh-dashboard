{
  "compilerOptions": {
    "target": "ES2025",
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",

    // Mirror webpack/Vite/Jest's `resolve.modules: ["src", ...]` so bare imports
    // like `import x from "utils/head"` or `components/Icon` type-resolve. TS 6
    // deprecated `baseUrl`, so use `paths` (resolved relative to this file): the
    // `*` catch-all maps bare specifiers into src/ and falls back to node_modules.
    "paths": {
      // The Vite build aliases `dygraphs` to its ES5 single-file build; mirror
      // that here so TS resolves the same module the bundler/Jest will load.
      "dygraphs": ["./node_modules/dygraphs/src-es5/dygraph.js"],
      "*": ["./src/*", "./*"]
    },

    // The strict-mode ratchet is complete: every strict sub-flag was enabled
    // and its errors fixed across phases, so `strict: true` is now a no-op
    // tightening that locks them all on. allowJs lets the remaining .js test
    // files coexist (checkJs stays off — tests are not type-checked yet).
    "allowJs": true,
    "checkJs": false,
    "strict": true,

    // Auto-inclusion of node_modules/@types doesn't resolve in this setup, and
    // the source uses no ambient @types globals (process/window/navigator come
    // from global.d.ts + lib DOM). Tests, however, rely on Jest's globals
    // (describe/it/expect/jest) and jest-dom's matchers, so list them
    // explicitly. `node` is intentionally omitted to avoid clashing with the
    // hand-rolled `process` declaration in global.d.ts.
    "types": ["jest", "@testing-library/jest-dom"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src", "global.d.ts"],
  "exclude": ["node_modules", "build", ".claude"]
}
