{
  "name": "gm-fabric-dashboard",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.22.3",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@reduxjs/toolkit": "^2.12.0",
    "color": "^5.0.3",
    "dygraphs": "~2.2.1",
    "filesize": "~11.0.19",
    "js-quantities": "^1.8.0",
    "object-sizeof": "^1.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-intl": "^10.1.14",
    "react-modal": "^3.16.3",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "react-select": "^5.10.2",
    "react-toastify": "^11.1.0",
    "redux": "^5.0.1",
    "redux-logger": "~3.0.6",
    "reselect": "~5.2.0",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dygraphs": "^2.1.11",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "@types/redux-logger": "^3.0.13",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.20",
    "babel-plugin-styled-components": "^1.4.0",
    "cors": "^2.8.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "express": "^4.21.2",
    "globals": "^17.7.0",
    "jest-styled-components": "^7.0.0",
    "jsdom": "^29.1.1",
    "npm-check": "^5.5.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "redux-mock-store": "^1.5.5",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "build": "vite build",
    "build-docker": "docker build -t deciphernow/gm-fabric-dashboard -f docker-prod/Dockerfile .",
    "build-storybook": "storybook build",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "lint-js": "node ./node_modules/eslint/bin/eslint src/",
    "typecheck": "tsc --noEmit",
    "mock-sds": "node json-mock/discovery-service/sds.js",
    "preview": "vite preview",
    "start": "npm-run-all --print-label --parallel start-ui mock-sds",
    "start-ui": "vite",
    "storybook": "storybook dev -p 6006",
    "test": "cross-env TZ=America/New_York vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "update-deps": "npm-check . --skip-unused -u",
    "update-snapshots": "cross-env CI=true TZ=America/New_York vitest run --update"
  },
  "prettier": {
    "bracketSpacing": true,
    "bracketSameLine": false,
    "printWidth": 80,
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 ChromeAndroid versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "Firefox ESR"
  ],
  "homepage": "./"
}
