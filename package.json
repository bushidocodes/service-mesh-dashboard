{
  "name": "gm-fabric-dashboard",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.22.3",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.12.0",
    "color": "^5.0.3",
    "dygraphs": "~2.1.0",
    "filesize": "~11.0.17",
    "js-quantities": "^1.7.0",
    "lodash": "~4.17.23",
    "object-sizeof": "^1.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-grid-layout": "^2.2.3",
    "react-intl": "^7.1.0",
    "react-modal": "^3.16.3",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.17.0",
    "react-select": "^5.10.2",
    "react-toastify": "^11.1.0",
    "redux": "^5.0.1",
    "redux-logger": "~3.0.6",
    "reselect": "~5.2.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.29.7",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dygraphs": "^2.1.11",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/react-modal": "^3.16.3",
    "@types/redux-logger": "^3.0.13",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-styled-components": "^1.4.0",
    "commander": "^12.1.0",
    "conventional-changelog": "^7.2.0",
    "cors": "^2.8.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "express": "^4.21.2",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-styled-components": "^7.0.0",
    "lint-staged": "^17.0.7",
    "npm-check": "^5.5.2",
    "npm-run-all": "^4.1.2",
    "prettier": "^3.5.0",
    "prompt": "^1.0.0",
    "redux-mock-store": "^1.3.0",
    "storybook": "^10.4.6",
    "testcafe": "^3.7.4",
    "testcafe-react-selectors": "^5.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.21"
  },
  "scripts": {
    "build": "vite build",
    "build-docker": "docker build -t deciphernow/gm-fabric-dashboard -f docker-prod/Dockerfile .",
    "build-storybook": "storybook build",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "draft-github-release": "node scripts/generateGitHubDraft.js",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "lint-js": "node ./node_modules/eslint/bin/eslint src/",
    "typecheck": "tsc --noEmit",
    "mock-sds": "node json-mock/discovery-service/sds.js",
    "prepare": "husky",
    "preview": "vite preview",
    "preversion": "NODE_ENV=test CI=true npm-run-all --print-label lint-js test test:e2e:local",
    "publish": "node scripts/publish.js",
    "start": "npm-run-all --print-label --parallel start-ui mock-sds",
    "start-ui": "vite",
    "storybook": "storybook dev -p 6006",
    "test": "cross-env TZ=America/New_York node scripts/test.js",
    "test:e2e:local": "testcafe chrome:headless ./e2e-tests/tests/*.js -a 'pnpm start' --app-init-delay 5000",
    "update-deps": "npm-check . --skip-unused -u",
    "update-snapshots": "CI=true pnpm run test -- --updateSnapshot",
    "version": "npm-run-all --print-label changelog update-snapshots && git add -A"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "prettier --write"
  },
  "jest": {
    "setupFiles": [
      "<rootDir>/config/polyfills.js",
      "<rootDir>/config/jest/jestSetup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/config/jest/jestTestFrameworkSetup.js"
    ],
    "testMatch": [
      "**/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "**/src/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.claude/worktrees/",
      "<rootDir>/src/Storyshots.test.js"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost",
      "customExportConditions": [
        "node",
        "node-addons",
        "require",
        "default"
      ]
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.cjs",
      "^(?!.*\\.(js|jsx|ts|tsx|css|json|cjs|mjs)$)": "<rootDir>/config/jest/fileTransform.cjs"
    },
    "transformIgnorePatterns": [
      "^(?!.*[/\\\\]node_modules[/\\\\](color|color-string|color-convert|color-name)[/\\\\]).*[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ],
    "moduleNameMapper": {
      "^@testing-library/react$": "<rootDir>/config/jest/rtlWrapper.cjs"
    },
    "moduleDirectories": [
      "node_modules",
      "<rootDir>/src"
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "json",
      "web.jsx",
      "jsx",
      "ts",
      "tsx"
    ]
  },
  "prettier": {
    "bracketSpacing": true,
    "bracketSameLine": false,
    "printWidth": 80,
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 ChromeAndroid versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "Firefox ESR"
  ],
  "homepage": "./"
}
