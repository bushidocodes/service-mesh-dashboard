{
  "name": "gm-fabric-dashboard",
  "version": "1.0.6",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "color": "^2.0.1",
    "dateformat": "^3.0.2",
    "dygraphs": "^2.1.0",
    "filesize": "~3.5.11",
    "js-quantities": "^1.7.0",
    "jumpstate": "~2.2.2",
    "lodash": "~4.17.4",
    "object-sizeof": "^1.2.0",
    "prop-types": "^15.6.0",
    "react": "^18.0.0",
    "react-collapse": "^5.1.1",
    "react-dom": "^18.0.0",
    "react-grid-layout": "^2.2.3",
    "react-intl": "^7.1.0",
    "react-modal": "^3.16.3",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.0.0",
    "react-select": "^5.10.2",
    "react-sparklines": "^1.7.0",
    "react-toastify": "^11.1.0",
    "redux": "^4.2.1",
    "redux-logger": "~3.0.6",
    "reselect": "~3.0.1",
    "styled-components": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@cfaester/enzyme-adapter-react-18": "^0.8.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-styled-components": "^1.4.0",
    "commander": "^2.12.2",
    "conventional-changelog-cli": "^1.3.5",
    "cors": "^2.8.4",
    "cross-env": "^5.1.1",
    "documentation": "^5.3.3",
    "enzyme": "^3.3.0",
    "enzyme-to-json": "^3.6.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "express": "^4.21.2",
    "glob-promise": "^3.3.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-styled-components": "^7.0.0",
    "junit-merge": "^1.2.3",
    "lint-staged": "^15.0.0",
    "node-glob": "^1.2.0",
    "npm-check": "^5.5.2",
    "npm-run-all": "^4.1.2",
    "prettier": "^3.5.0",
    "prompt": "^1.0.0",
    "raf": "^3.4.0",
    "react-test-renderer": "^18.0.0",
    "redux-mock-store": "^1.3.0",
    "replace-in-file": "^3.1.0",
    "storybook": "^10.0.0",
    "stylelint": "^8.4.0",
    "stylelint-config-standard": "^18.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-no-unsupported-browser-features": "^2.0.0",
    "stylelint-processor-styled-components": "^1.2.2",
    "testcafe": "^3.7.4",
    "testcafe-react-selectors": "^5.0.3",
    "vite": "^5.4.21",
    "whatwg-fetch": "^3.6.20"
  },
  "scripts": {
    "build": "vite build",
    "build-docker": "docker build -t deciphernow/gm-fabric-dashboard -f docker-prod/Dockerfile .",
    "build-storybook": "storybook build",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "draft-github-release": "node scripts/generateGitHubDraft.js",
    "docs": "cross-env NODE_ENV=production node ./node_modules/documentation/bin/documentation.js build src/index.js -f md -o docs.md",
    "format": "prettier --write 'src/**/*.{js,jsx}'",
    "junit-merge": "junit-merge",
    "lint-css": "stylelint --formatter string 'src/**/*.{js,jsx}'",
    "lint-js": "node ./node_modules/eslint/bin/eslint src/",
    "mock-sds": "node json-mock/discovery-service/sds.js",
    "prepare": "husky",
    "preview": "vite preview",
    "preversion": "NODE_ENV=test CI=true npm-run-all --print-label lint-css lint-js test test:e2e:local",
    "publish": "node scripts/publish.js",
    "start": "npm-run-all --print-label --parallel start-ui mock-sds",
    "start-ui": "vite",
    "storybook": "storybook dev -p 6006",
    "test": "cross-env TZ=America/New_York node scripts/test.js",
    "test:e2e:local": "testcafe chrome:headless ./e2e-tests/tests/*.js -a 'npm start' --app-init-delay 5000",
    "update-deps": "npm-check . --skip-unused -u",
    "update-snapshots": "CI=true npm run test -- --updateSnapshot",
    "version": "npm-run-all --print-label changelog update-snapshots && git add -A"
  },
  "lint-staged": {
    "*.js": "prettier --write"
  },
  "jest-junit": {
    "suiteName": "GM Fabric",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": "true"
  },
  "jest": {
    "setupFiles": [
      "<rootDir>/config/polyfills.js",
      "raf/polyfill",
      "<rootDir>/config/jest/jestSetup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/config/jest/jestTestFrameworkSetup.js"
    ],
    "snapshotSerializers": [
      "enzyme-to-json/serializer"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx}"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/src/Storyshots.test.js"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost",
      "customExportConditions": [
        "node",
        "node-addons",
        "require",
        "default"
      ]
    },
    "transform": {
      "^.+\\.(js|jsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|css|json|cjs|mjs)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web"
    },
    "moduleDirectories": [
      "node_modules",
      "<rootDir>/src"
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "json",
      "web.jsx",
      "jsx"
    ]
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "prettier": {
    "bracketSpacing": true,
    "bracketSameLine": false,
    "printWidth": 80,
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 ChromeAndroid versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 Firefox versions",
    "IE 11",
    "last 2 Edge versions",
    "Firefox ESR"
  ],
  "homepage": "./"
}
