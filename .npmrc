; Use the public registry for privately scoped packages because they may not be
; published to a private NPM registry used by this project.
registry = "https://registry.npmjs.org"

; NOTE (issue #108): as of pnpm 11, .npmrc is read ONLY for auth/registry
; settings. All other pnpm settings — the pinned Node.js version, peer-dependency
; strictness, and dependency build-script allowlist — live in pnpm-workspace.yaml.
