; Use the public registry for privately scoped packages because they may not be
; published to a private NPM registry used by this project.
registry = "https://registry.npmjs.org"

; One package still declares peerDependencies that exclude React 18:
;   react-notification-system@0.2.16 (0.14.x || ^15 || ^16)  — see #44 (abandoned)
; Until resolved, plain `npm install` needs to ignore the peer conflict. See #30.
legacy-peer-deps=true
