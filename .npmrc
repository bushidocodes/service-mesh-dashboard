; Use the public registry for privately scoped packages because they may not be
; published to a private NPM registry used by this project.
registry = "https://registry.npmjs.org"
@storybook/addon-actions:registry=registry

; Several pinned legacy packages (react-input-range, react-grid-layout, etc.)
; declare peerDependencies on React 15/16. The app runs on React 18; the
; legacy packages are confirmed working in practice and will be upgraded in
; future PRs. Until then, plain `npm install` needs to ignore the conflict.
legacy-peer-deps=true
