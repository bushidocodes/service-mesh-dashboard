; Use the public registry for privately scoped packages because they may not be
; published to a private NPM registry used by this project.
registry = "https://registry.npmjs.org"

; Some pinned dev/peer deps still declare conflicting peerDependencies, so plain
; `npm install` needs to ignore the conflict until they're resolved. See #30 for
; the remaining blockers (e.g. testcafe-react-selectors wants testcafe@^0.19.1).
; The React-18 blocker react-notification-system was removed in #44.
legacy-peer-deps=true
