; Use the public registry for privately scoped packages because they may not be
; published to a private NPM registry used by this project.
registry = "https://registry.npmjs.org"

; Two packages still declare peerDependencies that exclude React 18:
;   react-modal@3.1.10               (^0.14 || ^15 || ^16)         — see #49
;   react-notification-system@0.2.16 (0.14.x || ^15 || ^16)       — see #44
; Additionally, react-grid-layout@0.16.2 pulls in react-resizable@1.7.5
; transitively, which also excludes React 18 — resolved by the grid upgrade in #42.
; All run fine against React 18 in practice. Until all are resolved, plain
; `npm install` needs to ignore the peer conflict. See #30.
legacy-peer-deps=true
