; Use the public registry for privately scoped packages because they may not be
; published to a private NPM registry used by this project.
registry = "https://registry.npmjs.org"

; Three pinned packages still declare peerDependencies that exclude React 18:
;   react-modal@3.1.10              (^0.14 || ^15 || ^16)
;   react-resizable@1.7.5           (0.14.x || 15.x || 16.x)
;   react-notification-system@0.2.16 (0.14.x || ^15 || ^16)
; They run fine against React 18 in practice. react-modal and react-resizable
; can be bumped within/just past their majors; react-notification-system is
; abandoned (last release 2019) and needs replacing. Until all three are
; resolved, plain `npm install` needs to ignore the peer conflict. See #30.
legacy-peer-deps=true
